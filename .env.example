# Cuenta del bot (la que recibirá pagos y votará)
BOT_USERNAME=tucuenta
BOT_POSTING_KEY=5J...
BOT_ACTIVE_KEY=5J...

# Puerto del servidor web
PORT=3000

# Porcentaje de retorno (ej: 1.5 = 150% del pago en votos)
BOOST_MULTIPLIER=1.5

# Máximo de votos por día para no quemar mana
MAX_VOTES_PER_DAY=200

# Peso mínimo y máximo del voto (%) 
MIN_VOTE_PERCENT=1
MAX_VOTE_PERCENT=100

# Paquetes disponibles (formato: nombre:monto_hive:peso_voto_%)
PACKAGES=basico:1:50,plus:3:80,premium:5:100,pro:10:100
